generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  notes     Note[]
  tasks     Task[]
  chats     Chat[]
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  icon      String?  @default("📄")
  type      String   @default("note") // "welcome", "notes-grid", "tasks", "note"
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Task {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  status    String   // todo | in-progress | done
  priority  String   // low | medium | high
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Chat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  response  String
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}